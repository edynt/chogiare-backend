generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==================== NOTE: All enums removed ====================
// Enum values are now stored as integers in the database.
// See src/common/constants/enum.constants.ts for value mappings.
// ================================================================

model User {
  id             Int     @id @default(autoincrement())
  email          String  @unique @db.VarChar(255)
  hashedPassword String  @map("hashed_password") @db.VarChar(255)
  isVerified     Boolean @default(false) @map("is_verified")
  status         Boolean @default(true)
  language       Int     @default(0) // 0=vi, 1=en

  // Profile fields (merged from UserInfo)
  fullName        String? @map("full_name") @db.VarChar(255)
  avatarUrl       String? @map("avatar_url") @db.VarChar(500)
  gender          String? @db.VarChar(20)
  dateOfBirth     String? @map("date_of_birth") @db.VarChar(10)
  phoneNumber     String? @map("phone_number") @db.VarChar(20)
  address         String? @db.VarChar(500)
  country         String? @db.VarChar(100)
  profileMetadata Json?   @default("{}") @map("profile_metadata")

  // Seller fields (moved from Store model)
  isSeller          Boolean @default(false) @map("is_seller")
  sellerName        String? @map("seller_name") @db.VarChar(255)
  sellerSlug        String? @unique @map("seller_slug") @db.VarChar(255)
  sellerDescription String? @map("seller_description") @db.Text
  sellerLogo        String? @map("seller_logo") @db.VarChar(500)
  sellerBanner      String? @map("seller_banner") @db.VarChar(500)
  sellerRating      Decimal @default(0) @map("seller_rating") @db.Decimal(3, 2)
  sellerReviewCount Int     @default(0) @map("seller_review_count")
  sellerProductCount Int    @default(0) @map("seller_product_count")
  sellerIsVerified  Boolean @default(false) @map("seller_is_verified")
  sellerContactInfo Json    @default("{}") @map("seller_contact_info")
  sellerAddressInfo Json    @default("{}") @map("seller_address_info")
  sellerBusinessInfo Json   @default("{}") @map("seller_business_info")
  sellerBusinessHours Json  @default("{}") @map("seller_business_hours")
  sellerPolicies    Json    @default("{}") @map("seller_policies")
  sellerMetadata    Json    @default("{}") @map("seller_metadata")

  createdAt BigInt @map("created_at")
  updatedAt BigInt @map("updated_at")

  sessions           Session[]
  emailVerifications EmailVerification[]
  passwordResets     PasswordReset[]
  userRoles          UserRole[]
  products           Product[]
  cart               Cart?
  buyerOrders        Order[]             @relation("BuyerOrders")
  sellerOrders       Order[]             @relation("SellerOrders")
  addresses          Address[]
  reviews            Review[]
  conversations      ConversationParticipant[]
  messages           ChatMessage[]
  transactions       Transaction[]
  userBalance        UserBalance?
  notifications      Notification[]
  stockInRecords     StockInRecord[]
  ticketsCreated     SupportTicket[]           @relation("TicketUser")
  ticketsAssigned    SupportTicket[]           @relation("TicketAssignee")
  ticketReplies      TicketReply[]
  subscription       UserSubscription?

  @@index([email])
  @@index([status])
  @@index([isSeller])
  @@index([sellerSlug])
  @@map("users")
}

model Session {
  id           Int    @id @default(autoincrement())
  userId       Int    @map("user_id")
  refreshToken String @map("refresh_token") @db.VarChar(500)
  expiresAt    BigInt @map("expires_at")
  createdAt    BigInt @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
  @@index([expiresAt])
  @@map("sessions")
}

model EmailVerification {
  id        Int    @id @default(autoincrement())
  userId    Int    @map("user_id")
  code      String @db.VarChar(10)
  expiresAt BigInt @map("expires_at")
  createdAt BigInt @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([code])
  @@index([expiresAt])
  @@map("email_verifications")
}

model PasswordReset {
  id         Int     @id @default(autoincrement())
  userId     Int     @map("user_id")
  resetToken String  @map("reset_token") @db.VarChar(500)
  expiresAt  BigInt  @map("expires_at")
  used       Boolean @default(false)
  createdAt  BigInt  @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([resetToken])
  @@index([expiresAt])
  @@index([used])
  @@map("password_resets")
}

model Role {
  id          Int     @id @default(autoincrement())
  name        String  @unique @db.VarChar(50)
  description String? @db.VarChar(500)
  createdAt   BigInt  @map("created_at")

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@map("roles")
}

model Permission {
  id          Int     @id @default(autoincrement())
  name        String  @unique @db.VarChar(100)
  description String? @db.VarChar(500)
  createdAt   BigInt  @map("created_at")

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       Int @map("role_id")
  permissionId Int @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId Int @map("user_id")
  roleId Int @map("role_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model Category {
  id           Int     @id @default(autoincrement())
  name         String  @db.VarChar(255)
  slug         String  @unique @db.VarChar(255)
  description  String? @db.Text
  image        String? @db.VarChar(500)
  parentId     Int?    @map("parent_id")
  productCount Int     @default(0) @map("product_count")
  isActive     Boolean @default(true) @map("is_active")
  displayOrder Int     @default(0) @map("display_order")
  metadata     Json    @default("{}")
  createdAt    BigInt  @map("created_at")
  updatedAt    BigInt  @map("updated_at")

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryTree")
  products Product[]

  @@index([parentId])
  @@index([slug])
  @@index([isActive])
  @@index([displayOrder])
  @@map("categories")
}

model Product {
  id             Int     @id @default(autoincrement())
  sellerId       Int     @map("seller_id")
  categoryId     Int     @map("category_id")
  title          String  @db.VarChar(500)
  description    String? @db.Text
  price          Decimal @db.Decimal(15, 2)
  originalPrice  Decimal? @map("original_price") @db.Decimal(15, 2)
  condition      Int     // 0=new, 1=like_new, 2=good, 3=fair, 4=poor
  location       String? @db.VarChar(255)
  stock          Int     @default(0)
  minStock       Int     @default(0) @map("min_stock")
  maxStock       Int?    @map("max_stock")
  reservedStock  Int     @default(0) @map("reserved_stock")
  availableStock Int     @default(0) @map("available_stock")
  costPrice      Decimal? @map("cost_price") @db.Decimal(15, 2)
  sellingPrice   Decimal? @map("selling_price") @db.Decimal(15, 2)
  profit         Decimal? @db.Decimal(15, 2)
  profitMargin   Decimal? @map("profit_margin") @db.Decimal(5, 2)
  sku            String? @unique @db.VarChar(100)
  barcode        String? @db.VarChar(100)
  status         Int     @default(0) // 0=draft, 1=active, 2=out_of_stock
  rating         Decimal @default(0) @db.Decimal(3, 2)
  reviewCount    Int     @default(0) @map("review_count")
  viewCount      Int     @default(0) @map("view_count")
  salesCount     Int     @default(0) @map("sales_count")
  isFeatured     Boolean @default(false) @map("is_featured")
  isPromoted     Boolean @default(false) @map("is_promoted")
  boostEndAt     BigInt? @map("boost_end_at")
  tags           String[] @default([])
  badges         Int[]   @default([]) // Array of badge IDs: 0=NEW, 1=FEATURED, 2=PROMO, 3=HOT, 4=SALE
  warranty       String? @db.VarChar(500)
  returnPolicy   String? @map("return_policy") @db.Text
  inventoryInfo  Json    @default("{}") @map("inventory_info")
  metadata       Json    @default("{}")
  createdAt      BigInt  @map("created_at")
  updatedAt      BigInt  @map("updated_at")

  seller         User            @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  category       Category        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  images         ProductImage[]
  cartItems      CartItem[]
  orderItems     OrderItem[]
  reviews        Review[]
  stockInRecords StockInRecord[]
  boosts         ProductBoost[]

  @@index([sellerId])
  @@index([categoryId])
  @@index([status])
  @@index([isFeatured, isPromoted])
  @@index([isPromoted])
  @@index([boostEndAt])
  @@index([sku])
  @@index([createdAt])
  @@map("products")
}

model ProductBoost {
  id           Int     @id @default(autoincrement())
  productId    Int     @map("product_id")
  packageId    Int     @map("package_id")
  pricePaid    Decimal @map("price_paid") @db.Decimal(15, 2)
  durationDays Int     @map("duration_days")
  startAt      BigInt  @map("start_at")
  endAt        BigInt  @map("end_at")
  isActive     Boolean @default(true) @map("is_active")
  createdAt    BigInt  @map("created_at")

  product Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  package ServicePackage @relation(fields: [packageId], references: [id], onDelete: Restrict)

  @@index([productId])
  @@index([packageId])
  @@index([isActive])
  @@index([endAt])
  @@map("product_boosts")
}

model ProductImage {
  id           Int    @id @default(autoincrement())
  productId    Int    @map("product_id")
  imageUrl     String @map("image_url") @db.VarChar(500)
  displayOrder Int    @default(0) @map("display_order")
  createdAt    BigInt @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([productId, displayOrder])
  @@map("product_images")
}

model Cart {
  id        Int    @id @default(autoincrement())
  userId    Int    @unique @map("user_id")
  createdAt BigInt @map("created_at")
  updatedAt BigInt @map("updated_at")

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@index([userId])
  @@map("carts")
}

model CartItem {
  id        Int     @id @default(autoincrement())
  cartId    Int     @map("cart_id")
  productId Int     @map("product_id")
  quantity  Int
  price     Decimal @db.Decimal(15, 2)
  createdAt BigInt  @map("created_at")
  updatedAt BigInt  @map("updated_at")

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
  @@map("cart_items")
}

model Order {
  id                Int     @id @default(autoincrement())
  orderNo           String? @unique @map("order_no") @db.VarChar(30)
  buyerId           Int     @map("buyer_id")
  sellerId          Int     @map("seller_id")
  status            Int     @default(0) // 0=pending, 1=confirmed, 2=preparing, 3=ready_for_pickup, 4=completed, 5=cancelled, 6=refunded
  paymentStatus     Int     @default(0) @map("payment_status") // 0=pending, 1=completed, 2=failed, 3=refunded
  paymentMethod     Int?    @map("payment_method") // 0=bank_transfer
  subtotal          Decimal @db.Decimal(15, 2)
  tax               Decimal @default(0) @db.Decimal(15, 2)
  shipping          Decimal @default(0) @db.Decimal(15, 2)
  discount          Decimal @default(0) @db.Decimal(15, 2)
  total             Decimal @db.Decimal(15, 2)
  currency          String  @default("VND") @db.VarChar(10)
  shippingAddressId Int?    @map("shipping_address_id")
  billingAddressId  Int?    @map("billing_address_id")
  notes             String? @db.Text
  sellerNotes       String? @map("seller_notes") @db.Text
  paymentImage      String? @map("payment_image") @db.VarChar(500)
  orderMetadata     Json    @default("{}") @map("order_metadata")
  createdAt         BigInt  @map("created_at")
  updatedAt         BigInt  @map("updated_at")

  buyer           User          @relation("BuyerOrders", fields: [buyerId], references: [id], onDelete: Restrict)
  seller          User          @relation("SellerOrders", fields: [sellerId], references: [id], onDelete: Restrict)
  shippingAddress Address?      @relation("ShippingAddress", fields: [shippingAddressId], references: [id], onDelete: SetNull)
  billingAddress  Address?      @relation("BillingAddress", fields: [billingAddressId], references: [id], onDelete: SetNull)
  items           OrderItem[]
  transactions    Transaction[]

  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@index([paymentStatus])
  @@index([status, paymentStatus])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id           Int     @id @default(autoincrement())
  orderId      Int     @map("order_id")
  productId    Int     @map("product_id")
  productName  String  @map("product_name") @db.VarChar(500)
  productImage String? @map("product_image") @db.VarChar(500)
  price        Decimal @db.Decimal(15, 2)
  quantity     Int
  subtotal     Decimal @db.Decimal(15, 2)
  itemMetadata Json    @default("{}") @map("item_metadata")
  createdAt    BigInt  @map("created_at")
  updatedAt    BigInt  @map("updated_at")

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Address {
  id              Int     @id @default(autoincrement())
  userId          Int     @map("user_id")
  recipientName   String  @map("recipient_name") @db.VarChar(255)
  recipientPhone  String  @map("recipient_phone") @db.VarChar(20)
  street          String  @db.VarChar(500)
  city            String  @db.VarChar(100)
  state           String  @db.VarChar(100)
  district        String? @db.VarChar(100)
  ward            String? @db.VarChar(100)
  zipCode         String  @map("zip_code") @db.VarChar(20)
  country         String  @default("Vietnam") @db.VarChar(100)
  isDefault       Boolean @default(false) @map("is_default")
  addressMetadata Json    @default("{}") @map("address_metadata")
  createdAt       BigInt  @map("created_at")
  updatedAt       BigInt  @map("updated_at")

  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  shippingOrders Order[] @relation("ShippingAddress")
  billingOrders  Order[] @relation("BillingAddress")

  @@index([userId])
  @@index([userId, isDefault])
  @@map("addresses")
}

model Review {
  id             Int     @id @default(autoincrement())
  productId      Int     @map("product_id")
  userId         Int     @map("user_id")
  orderId        Int?    @map("order_id")
  rating         Int
  title          String? @db.VarChar(255)
  comment        String? @db.Text
  isVerified     Boolean @default(false) @map("is_verified")
  reviewMetadata Json    @default("{}") @map("review_metadata")
  createdAt      BigInt  @map("created_at")
  updatedAt      BigInt  @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId, orderId])
  @@index([productId])
  @@index([userId])
  @@index([orderId])
  @@index([rating])
  @@index([isVerified])
  @@index([createdAt])
  @@map("reviews")
}

model Conversation {
  id        Int    @id @default(autoincrement())
  type      Int    @default(0) // 0=direct, 1=group
  title     String? @db.VarChar(255)
  metadata  Json   @default("{}")
  createdAt BigInt @map("created_at")
  updatedAt BigInt @map("updated_at")

  participants ConversationParticipant[]
  messages     ChatMessage[]

  @@index([type])
  @@index([updatedAt])
  @@map("conversations")
}

model ConversationParticipant {
  id             Int     @id @default(autoincrement())
  conversationId Int     @map("conversation_id")
  userId         Int     @map("user_id")
  role           String? @db.VarChar(50)
  joinedAt       BigInt  @map("joined_at")
  lastReadAt     BigInt? @map("last_read_at")
  metadata       Json    @default("{}")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@index([userId])
  @@map("conversation_participants")
}

model ChatMessage {
  id              Int    @id @default(autoincrement())
  conversationId  Int    @map("conversation_id")
  senderId        Int    @map("sender_id")
  messageType     Int    @default(0) @map("message_type") // 0=text, 1=image, 2=file
  content         String @db.Text
  isRead          Boolean @default(false) @map("is_read")
  messageMetadata Json   @default("{}") @map("message_metadata")
  createdAt       BigInt @map("created_at")
  updatedAt       BigInt @map("updated_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@index([conversationId, createdAt])
  @@index([isRead])
  @@map("chat_messages")
}

model Transaction {
  id                  Int     @id @default(autoincrement())
  userId              Int     @map("user_id")
  type                Int     // 0=deposit, 1=sale, 2=refund, 3=commission, 4=bonus, 5=subscription_purchase, 6=boost
  amount              Decimal @db.Decimal(15, 2)
  currency            String  @default("VND") @db.VarChar(10)
  status              String  @default("pending") @db.VarChar(50)
  paymentMethod       Int?    @map("payment_method") // 0=bank_transfer
  reference           String? @db.VarChar(255)
  description         String? @db.Text
  orderId             Int?    @map("order_id")
  transactionMetadata Json    @default("{}") @map("transaction_metadata")
  createdAt           BigInt  @map("created_at")
  updatedAt           BigInt  @map("updated_at")

  user  User   @relation(fields: [userId], references: [id], onDelete: Restrict)
  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([orderId])
  @@index([createdAt])
  @@map("transactions")
}

model UserBalance {
  id        Int     @id @default(autoincrement())
  userId    Int     @unique @map("user_id")
  balance   Decimal @default(0) @db.Decimal(15, 2)
  updatedAt BigInt  @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_balances")
}

model StockInRecord {
  id             Int      @id @default(autoincrement())
  productId      Int      @map("product_id")
  quantity       Int
  costPrice      Decimal? @map("cost_price") @db.Decimal(15, 2)
  supplier       String?  @db.VarChar(255)
  notes          String?  @db.Text
  createdBy      Int      @map("created_by")
  recordMetadata Json     @default("{}") @map("record_metadata")
  createdAt      BigInt   @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  creator User    @relation(fields: [createdBy], references: [id], onDelete: Restrict)

  @@index([productId])
  @@index([createdBy])
  @@index([createdAt])
  @@map("stock_in_records")
}

model Notification {
  id                   Int    @id @default(autoincrement())
  userId               Int    @map("user_id")
  type                 Int    // 0=order, 1=product, 2=payment, 3=system, 4=promotion, 5=message
  title                String @db.VarChar(255)
  message              String @db.Text
  actionUrl            String? @map("action_url") @db.VarChar(500)
  isRead               Boolean @default(false) @map("is_read")
  notificationMetadata Json   @default("{}") @map("notification_metadata")
  createdAt            BigInt @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([type])
  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ==================== SUPPORT TICKETS ====================

model SupportTicket {
  id          Int    @id @default(autoincrement())
  userId      Int    @map("user_id")
  assignedTo  Int?   @map("assigned_to")
  category    Int    // 0=account, 1=product, 2=payment, 3=technical, 4=report, 5=question, 6=other
  priority    Int    @default(1) // 0=low, 1=medium, 2=high, 3=urgent
  status      Int    @default(0) // 0=open, 1=in_progress, 2=pending, 3=resolved, 4=closed
  title       String @db.VarChar(500)
  description String @db.Text
  tags        String[] @default([])
  metadata    Json   @default("{}")
  createdAt   BigInt @map("created_at")
  updatedAt   BigInt @map("updated_at")
  resolvedAt  BigInt? @map("resolved_at")

  user        User               @relation("TicketUser", fields: [userId], references: [id], onDelete: Cascade)
  assignee    User?              @relation("TicketAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)
  replies     TicketReply[]
  attachments TicketAttachment[]

  @@index([userId])
  @@index([assignedTo])
  @@index([status])
  @@index([priority])
  @@index([category])
  @@index([createdAt])
  @@map("support_tickets")
}

model TicketReply {
  id         Int     @id @default(autoincrement())
  ticketId   Int     @map("ticket_id")
  userId     Int     @map("user_id")
  message    String  @db.Text
  isInternal Boolean @default(false) @map("is_internal")
  metadata   Json    @default("{}")
  createdAt  BigInt  @map("created_at")

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([userId])
  @@index([createdAt])
  @@map("ticket_replies")
}

model TicketAttachment {
  id        Int    @id @default(autoincrement())
  ticketId  Int    @map("ticket_id")
  fileName  String @map("file_name") @db.VarChar(255)
  fileUrl   String @map("file_url") @db.VarChar(500)
  fileType  String @map("file_type") @db.VarChar(100)
  fileSize  Int    @map("file_size")
  createdAt BigInt @map("created_at")

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("ticket_attachments")
}

// ==================== SYSTEM SETTINGS ====================

model SystemSetting {
  id          Int    @id @default(autoincrement())
  key         String @unique @db.VarChar(255)
  value       String @db.Text
  type        Int    @default(0) // 0=string, 1=number, 2=boolean, 3=json, 4=text
  group       String @db.VarChar(100)
  label       String @db.VarChar(255)
  description String? @db.Text
  isPublic    Boolean @default(false) @map("is_public")
  isEditable  Boolean @default(true) @map("is_editable")
  metadata    Json   @default("{}")
  updatedBy   Int?   @map("updated_by")
  createdAt   BigInt @map("created_at")
  updatedAt   BigInt @map("updated_at")

  @@index([key])
  @@index([group])
  @@index([isPublic])
  @@map("system_settings")
}

// ==================== API KEYS ====================

model ApiKey {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(255)
  key         String   @unique @db.VarChar(255)
  secret      String   @db.VarChar(500)
  permissions String[] @default([])
  rateLimit   Int      @default(1000) @map("rate_limit")
  isActive    Boolean  @default(true) @map("is_active")
  lastUsedAt  BigInt?  @map("last_used_at")
  expiresAt   BigInt?  @map("expires_at")
  createdBy   Int      @map("created_by")
  metadata    Json     @default("{}")
  createdAt   BigInt   @map("created_at")
  updatedAt   BigInt   @map("updated_at")

  @@index([key])
  @@index([isActive])
  @@index([createdBy])
  @@map("api_keys")
}

// ==================== DEPOSIT PACKAGES ====================

model DepositPackage {
  id           Int     @id @default(autoincrement())
  name         String  @db.VarChar(255)
  amount       Decimal @db.Decimal(15, 2)
  displayOrder Int     @default(0) @map("display_order")
  isActive     Boolean @default(true) @map("is_active")
  createdAt    BigInt  @map("created_at")
  updatedAt    BigInt  @map("updated_at")

  @@index([isActive])
  @@index([displayOrder])
  @@map("deposit_packages")
}

// ==================== SERVICE PACKAGES ====================

model ServicePackage {
  id           Int     @id @default(autoincrement())
  name         String  @db.VarChar(255)
  displayName  String  @map("display_name") @db.VarChar(255)
  description  String? @db.Text
  durationDays Int     @map("duration_days")
  price        Decimal @db.Decimal(15, 2)
  isActive     Boolean @default(true) @map("is_active")
  displayOrder Int     @default(0) @map("display_order")
  features     Json    @default("[]")
  metadata     Json    @default("{}")
  createdAt    BigInt  @map("created_at")
  updatedAt    BigInt  @map("updated_at")

  purchases     SubscriptionPurchase[]
  productBoosts ProductBoost[]

  @@index([isActive])
  @@index([displayOrder])
  @@map("service_packages")
}

model UserSubscription {
  id        Int     @id @default(autoincrement())
  userId    Int     @unique @map("user_id")
  expiresAt BigInt? @map("expires_at")
  isActive  Boolean @default(false) @map("is_active")
  createdAt BigInt  @map("created_at")
  updatedAt BigInt  @map("updated_at")

  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  purchases SubscriptionPurchase[]

  @@index([userId])
  @@index([expiresAt])
  @@index([isActive])
  @@map("user_subscriptions")
}

model SubscriptionPurchase {
  id                     Int     @id @default(autoincrement())
  subscriptionId         Int     @map("subscription_id")
  packageId              Int     @map("package_id")
  purchasedAt            BigInt  @map("purchased_at")
  durationDays           Int     @map("duration_days")
  pricePaid              Decimal @map("price_paid") @db.Decimal(15, 2)
  expiresAtAfterPurchase BigInt  @map("expires_at_after_purchase")
  metadata               Json    @default("{}")

  subscription UserSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  package      ServicePackage   @relation(fields: [packageId], references: [id], onDelete: Restrict)

  @@index([subscriptionId])
  @@index([packageId])
  @@index([purchasedAt])
  @@map("subscription_purchases")
}
