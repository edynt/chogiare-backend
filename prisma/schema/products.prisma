// ============================================
// PRODUCT MANAGEMENT (Enhanced with Wholesale)
// ============================================

model Product {
  id              String          @id @default(uuid())
  title            String
  description      String?
  price            Decimal        @db.Decimal(15, 2) // Retail price
  originalPrice    Decimal?       @map("original_price") @db.Decimal(15, 2)
  wholesalePrice   Decimal?       @map("wholesale_price") @db.Decimal(15, 2) // Wholesale price
  minOrderQuantity Int?           @map("min_order_quantity") // MOQ for wholesale
  categoryId       String         @map("category_id")
  sellerId         String         @map("seller_id")
  storeId          String?        @map("store_id")
  condition        ProductCondition
  tags             String[]
  location         String?
  stock            Int            @default(0)
  minStock         Int            @default(0) @map("min_stock")
  maxStock         Int?           @map("max_stock")
  reservedStock    Int            @default(0) @map("reserved_stock")
  availableStock   Int            @default(0) @map("available_stock")
  costPrice        Decimal?       @map("cost_price") @db.Decimal(15, 2)
  sellingPrice     Decimal?       @map("selling_price") @db.Decimal(15, 2)
  profit           Decimal?       @db.Decimal(15, 2)
  profitMargin     Decimal?       @map("profit_margin") @db.Decimal(5, 2)
  sku              String?         @unique
  barcode          String?
  weight           Decimal?        @db.Decimal(10, 3)
  dimensions       String?
  supplier         String?
  status           ProductStatus  @default(draft)
  badges           ProductBadge[]
  rating           Decimal       @default(0) @db.Decimal(3, 2)
  reviewCount      Int            @default(0) @map("review_count")
  viewCount        Int            @default(0) @map("view_count")
  salesCount       Int            @default(0) @map("sales_count")
  isFeatured       Boolean        @default(false) @map("is_featured")
  isPromoted       Boolean        @default(false) @map("is_promoted")
  isActive         Boolean        @default(true) @map("is_active")
  createdAt        BigInt         @map("created_at")
  updatedAt        BigInt         @map("updated_at")

  category         Category       @relation(fields: [categoryId], references: [id])
  seller           User           @relation(fields: [sellerId], references: [id])
  store            Store?         @relation(fields: [storeId], references: [id], onDelete: SetNull)
  images           ProductImage[]
  orderItems       OrderItem[]
  cartItems        CartItem[]
  reviews          Review[]
  stockInRecords   StockInRecord[]
  stockAlerts      StockAlerts[]
  productBoosts    ProductBoost[]
  productWarehouses ProductWarehouse[]
  pricingTiers     PricingTier[]

  @@index([categoryId])
  @@index([sellerId])
  @@index([storeId])
  @@index([status])
  @@index([isActive])
  @@index([sku])
  @@index([isFeatured])
  @@index([isPromoted])
  @@map("products")
}

model ProductImage {
  id          Int      @id @default(autoincrement())
  productId   String   @map("product_id")
  imageUrl    String   @map("image_url")
  displayOrder Int     @default(0) @map("display_order")
  createdAt   BigInt   @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

// Wholesale Pricing Tiers
model PricingTier {
  id          String   @id @default(uuid())
  productId   String   @map("product_id")
  minQuantity Int      @map("min_quantity")
  maxQuantity Int?     @map("max_quantity")
  price       Decimal  @db.Decimal(15, 2)
  discount    Decimal? @db.Decimal(5, 2) // Percentage discount
  createdAt   BigInt   @map("created_at")
  updatedAt   BigInt   @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([minQuantity])
  @@map("pricing_tiers")
}

// Product Warehouse Inventory
model ProductWarehouse {
  id          String   @id @default(uuid())
  productId   String   @map("product_id")
  warehouseId String   @map("warehouse_id")
  stock       Int      @default(0)
  reservedStock Int    @default(0) @map("reserved_stock")
  availableStock Int   @default(0) @map("available_stock")
  createdAt   BigInt   @map("created_at")
  updatedAt   BigInt   @map("updated_at")

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([productId, warehouseId])
  @@index([productId])
  @@index([warehouseId])
  @@map("product_warehouses")
}

