// ============================================
// SHIPPING MANAGEMENT
// ============================================

model Shipping {
  id              String   @id @default(uuid())
  orderId         String   @unique @map("order_id")
  trackingNumber  String?  @unique @map("tracking_number")
  carrier         String?
  status          String?
  currentLocation String?  @map("current_location")
  estimatedDelivery BigInt? @map("estimated_delivery")
  createdAt       BigInt   @map("created_at")
  updatedAt       BigInt   @map("updated_at")

  order   Order            @relation("OrderShipping", fields: [orderId], references: [id], onDelete: Cascade)
  history ShippingHistory[]

  @@index([trackingNumber])
  @@map("shipping")
}

model ShippingHistory {
  id          Int      @id @default(autoincrement())
  shippingId String   @map("shipping_id")
  status      String
  location    String?
  description String?
  timestamp   BigInt
  createdAt   BigInt   @map("created_at")

  shipping Shipping @relation(fields: [shippingId], references: [id], onDelete: Cascade)

  @@index([shippingId])
  @@map("shipping_history")
}

