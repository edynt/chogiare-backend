# ============================================================
# Chogiare Backend - Environment Variables
# Copy to .env and fill in production values
# ============================================================

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:YOUR_STRONG_PASSWORD@postgres:5432/chogiare?schema=public"
POSTGRES_PASSWORD=  # Required for docker-compose PostgreSQL container

# JWT Configuration
JWT_SECRET="CHANGE_ME_GENERATE_A_STRONG_SECRET"
JWT_EXPIRES_IN="1h"
JWT_REFRESH_SECRET="CHANGE_ME_GENERATE_ANOTHER_STRONG_SECRET"
JWT_REFRESH_EXPIRES_IN="7d"

# JWT Admin Configuration
JWT_ADMIN_SECRET="CHANGE_ME_ADMIN_SECRET"
JWT_ADMIN_REFRESH_SECRET="CHANGE_ME_ADMIN_REFRESH_SECRET"

# Application
NODE_ENV="production"
PORT=3000
API_PREFIX="api"

# CORS (comma-separated origins)
CORS_ORIGIN="https://chogiare.online,https://www.chogiare.online"

# Redis
REDIS_URL="redis://redis:6379"
REDIS_PASSWORD="CHANGE_ME_REDIS_PASSWORD"

# Email (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_SECURE=false
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM_NAME="Chợ Giá Rẻ"
MAIL_FROM_EMAIL=your-email@gmail.com

# Frontend URL
FRONTEND_URL=https://chogiare.online

# Upload Provider (s3 | cloudinary)
UPLOAD_PROVIDER=cloudinary

# Cloudinary
CLOUDINARY_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_UPLOAD_FOLDER=your-folder

# Backup
BACKUP_RECIPIENT_EMAIL=your-backup-email@gmail.com
BACKUP_SECRET=your-backup-secret

# SePay Payment Gateway
SEPAY_API_KEY=your-sepay-api-key
SEPAY_BANK_NAME=Sacombank
SEPAY_ACCOUNT_NUMBER=your-account-number
SEPAY_ACCOUNT_NAME=YOUR_NAME
